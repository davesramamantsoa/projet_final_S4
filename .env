#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost:8080/'
app.forceGlobalSecureRequests = false
app.sessionDriver = 'CodeIgniter\Session\Handlers\FileSessionHandler'
app.sessionCookieName = 'mobile_money_session'
app.sessionExpiration = 7200
app.sessionSavePath = null
app.sessionMatchIP = false
app.sessionTimeToUpdate = 300
app.sessionRegenerateDestroy = false
app.defaultLocale = 'fr'
app.supportedLocales = ['fr']
app.timezone = 'Indian/Antananarivo'

#--------------------------------------------------------------------
# DATABASE - SQLite embarqué
# Le chemin est défini dans app/Config/Database.php avec WRITEPATH
# (chemin absolu vers writable/database/money.db)
# Décommentez uniquement si vous voulez override manuellement :
#--------------------------------------------------------------------
# database.default.DBDriver = SQLite3
# database.default.database = /chemin/absolu/vers/writable/database/money.db

#--------------------------------------------------------------------
# SECURITY (CSRF)
#--------------------------------------------------------------------
security.csrfProtection = 'cookie'
security.tokenRandomize = true
security.tokenName = 'csrf_token'
security.headerName = 'X-CSRF-TOKEN'
security.cookieName = 'csrf_cookie'
security.expires = 7200
security.regenerate = true
security.redirect = false
security.samesite = 'Lax'

#--------------------------------------------------------------------
# OPERATEUR ADMIN (authentification sans table DB)
#--------------------------------------------------------------------
operator.username = admin
operator.password = Admin@1234

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------
logger.threshold = 4
