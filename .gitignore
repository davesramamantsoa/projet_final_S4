# Vendor (CodeIgniter 4 framework installé via Composer)
/vendor/

# Base de données SQLite (générée automatiquement)
/writable/database/*.db
/writable/database/*.sqlite

# Logs
/writable/logs/*.log

# Cache
/writable/cache/*
!/writable/cache/.gitkeep

# Sessions
/writable/session/*
!/writable/session/.gitkeep

# .env (contient des informations sensibles)
# .env

